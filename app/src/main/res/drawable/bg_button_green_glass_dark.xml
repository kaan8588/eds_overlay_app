<?xml version="1.0" encoding="utf-8"?>
<!-- Dark mode: subtle, muted reflection -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#30FFFFFF">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <!-- Ana Cam Gövde -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#DD388E3C" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#30FFFFFF" />
                </shape>
            </item>
            <!-- Yansıtıcı Üst Katman — karanlık modda soluk, koyu yansıma -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <gradient
                        android:angle="135"
                        android:startColor="#2881C784"
                        android:centerColor="#0A4CAF50"
                        android:endColor="#00000000"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
