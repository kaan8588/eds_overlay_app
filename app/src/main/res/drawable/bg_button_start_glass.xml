<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dış Parlama (Green Glow) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:startColor="#004CAF50"
                android:centerColor="#204CAF50"
                android:endColor="#004CAF50"
                android:angle="0" />
        </shape>
    </item>
    <!-- Cam Gövde -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#254CAF50" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
    <!-- Yansıma -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="#30FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
