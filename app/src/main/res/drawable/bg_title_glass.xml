<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Green Glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#004CAF50"
                android:centerColor="#0A4CAF50"
                android:endColor="#004CAF50"
                android:angle="0" />
        </shape>
    </item>

    <!-- Glass Body -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>

    <!-- Reflection -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="135"
                android:startColor="#40C8E6CA"
                android:centerColor="#0CA5D6A7"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
