<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_light">

    <com.eds.overlay.ui.GlowParticlesView
        android:id="@+id/glow_particles"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


    <ScrollView
        android:id="@+id/scroll_view_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_main_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

        <FrameLayout
            android:id="@+id/fl_logo_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/iv_logo_glow"
                android:layout_width="165dp"
                android:layout_height="165dp"
                android:layout_gravity="center"
                android:alpha="0.8"
                android:scaleType="fitCenter"
                android:src="@drawable/bg_glow_green"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/iv_logo_main"
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:src="@drawable/muavinsonekran"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="@string/main_quote_default"
            android:textColor="#4DFFFFFF"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/layout_status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="@string/status"
                android:textAllCaps="true"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_service_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/status_inactive"
                android:textColor="#FF5252"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_green_glass"
            android:padding="0dp"
            android:stateListAnimator="@animator/btn_press_animator"
            android:text="@string/start_service"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/info_text"
            android:textColor="#40FFFFFF"
            android:textSize="11sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_feedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_feedback_glass"
            android:letterSpacing="0.05"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:stateListAnimator="@animator/btn_press_animator"
            android:text="@string/feedback_button"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn_import"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.05"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/import_data"
            android:textColor="#20FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_point_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:letterSpacing="0.02"
            android:text="@string/points_loading"
            android:textColor="#15FFFFFF"
            android:textSize="9sp" />
    </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_theme"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="@string/theme_switch"
        android:textColor="#4DFFFFFF"
        android:textSize="11sp" />

    <Button
        android:id="@+id/btn_language"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="@string/language_switch"
        android:textColor="#4DFFFFFF"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/layout_onboarding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2121212"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_ob_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ob_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#B0FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_ob_next"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:textColor="#121212"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF" />
    </LinearLayout>

</FrameLayout>
